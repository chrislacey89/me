---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  href: string
  title: string
  description: string
  comingSoon?: boolean
  imageSrc?: ImageMetadata
  id?: string
  class?: string
}

const { href, title, description, comingSoon = false, imageSrc, id, class: className } = Astro.props
---

<article class:list={['project-card-wrapper h-full', className]} transition:name={id ? `project-card-${id}` : undefined}>
  <a href={href} class="project-card group">
    {imageSrc && (
      <div class="card-image">
        <Image
          src={imageSrc}
          alt=""
          class="w-full h-full object-cover"
          width={480}
          height={200}
        />
      </div>
    )}
    <div class="card-body">
      <h3 class="card-title" transition:name={id ? `project-title-${id}` : undefined}>
        {title}
      </h3>
      <p class="card-description" transition:name={id ? `project-desc-${id}` : undefined}>
        {description}
      </p>
      <div class="card-footer">
        {comingSoon ? (
          <span class="card-status">Case study coming soon</span>
        ) : (
          <span class="card-cta">
            Read case study
            <span aria-hidden="true" class="cta-arrow">→</span>
          </span>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .project-card-wrapper {
    display: block;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-background);
    border: 1px solid var(--color-rule);
    border-radius: 0;
    text-decoration: none;
    color: var(--color-foreground);
    transition: border-color 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--color-forest-floor);
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--color-rule);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.5rem;
    gap: 0.75rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
    margin: 0;
  }

  .card-description {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    padding-top: 0.5rem;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .cta-arrow {
    transition: transform 0.2s ease;
  }

  .project-card:hover .cta-arrow {
    transform: translateX(3px);
  }

  .card-status {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
