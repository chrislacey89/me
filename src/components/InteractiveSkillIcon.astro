---
import SkillIcon from './SkillIcon.astro'

interface Props {
  icon: string
  name: string
  class?: string
}

const { icon, name, class: className } = Astro.props
---

<div class:list={['skill-icon-wrapper', className]}>
  <div class="skill-icon-box">
    <SkillIcon icon={icon} name={name} />
  </div>
  <span class="skill-icon-label">{name}</span>
</div>

<style>
  .skill-icon-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .skill-icon-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border: 1px solid var(--color-rule);
    color: var(--color-foreground);
    background: var(--color-background);
    transition: border-color 0.2s ease;
  }

  .skill-icon-wrapper:hover .skill-icon-box {
    border-color: var(--color-forest-floor);
  }

  .skill-icon-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-muted);
    text-align: center;
    max-width: 4.5rem;
    line-height: 1.2;
  }
</style>
