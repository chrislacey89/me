---
interface Props {
  currentPath: string
}

const { currentPath } = Astro.props

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'Writing', href: '/writing' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
]

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/'
  return current.startsWith(href)
}
---

<header class="nav-header" id="nav-header">
  <nav class="nav-container" aria-label="Primary">
    <a href="/" class="nav-logo">Chris Lacey</a>

    <!-- Desktop navigation -->
    <ul class="nav-desktop" role="list">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { active: isActive(item.href, currentPath) }]}
              aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
              data-astro-prefetch="viewport"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile: native <details>/<summary> baseline, progressively enhanced -->
    <details class="mobile-menu" id="mobile-menu">
      <summary class="hamburger" aria-label="Menu">
        <span class="sr-only">Menu</span>
        <span class="hamburger-icon" aria-hidden="true">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </span>
      </summary>

      <div class="mobile-overlay">
        <ul class="mobile-nav-list" role="list">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={['mobile-nav-link', { active: isActive(item.href, currentPath) }]}
                  aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
                  data-astro-prefetch="viewport"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </details>
  </nav>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-background);
    border-bottom: 1px solid var(--color-rule);
  }

  .nav-container {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
  }

  @media (min-width: 768px) {
    .nav-container {
      padding: 1rem 3rem;
    }
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .nav-logo:hover {
    color: var(--color-accent);
  }

  /* Desktop navigation */
  .nav-desktop {
    display: none;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    position: relative;
    display: inline-block;
    padding: 0.5rem 0;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-foreground);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link.active {
    color: var(--color-foreground);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--color-accent);
  }

  /* Mobile menu — <details>/<summary> baseline */
  .mobile-menu {
    display: block;
  }

  @media (min-width: 768px) {
    .mobile-menu {
      display: none;
    }
  }

  /* Remove the default disclosure triangle */
  .mobile-menu > summary {
    list-style: none;
  }

  .mobile-menu > summary::-webkit-details-marker {
    display: none;
  }

  .hamburger {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    touch-action: manipulation;
  }

  .hamburger-icon {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 24px;
    height: 18px;
    gap: 6px;
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-foreground);
    transition: transform 0.2s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  .mobile-menu[open] .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .mobile-menu[open] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu[open] .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* The overlay: no-JS baseline positions it absolutely below the header.
     JS-enhanced path promotes it to a full-screen panel via body scroll lock
     and a class toggle on <body>. CSS-only still fully reachable. */
  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 6rem 2rem 4rem;
    background: var(--color-background);
    overflow-y: auto;
  }

  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mobile-nav-link {
    display: block;
    padding: 1.25rem 0;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 7vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
  }

  .mobile-nav-link.active {
    color: var(--color-accent);
  }

  :global(body.menu-open) {
    overflow: hidden;
    touch-action: none;
    overscroll-behavior: none;
  }
</style>

<script>
  // Progressive enhancement for the native <details>/<summary> baseline.
  // The menu is fully usable without this script — it just improves focus
  // handling, body scroll lock, and keyboard close behavior.
  class MobileMenu {
    private details: HTMLDetailsElement | null = null
    private abortController: AbortController | null = null

    constructor() {
      this.init()
    }

    private init() {
      this.cleanup()
      this.details = document.getElementById('mobile-menu') as HTMLDetailsElement | null
      if (!this.details) return

      this.abortController = new AbortController()
      const { signal } = this.abortController

      this.details.addEventListener('toggle', this.handleToggle, { signal })

      document.addEventListener(
        'keydown',
        (e: KeyboardEvent) => {
          if (e.key === 'Escape' && this.details?.open) {
            this.close()
          }
        },
        { signal },
      )

      this.details.addEventListener(
        'click',
        (e) => {
          const link = (e.target as HTMLElement).closest('a.mobile-nav-link')
          if (link) this.close()
        },
        { signal },
      )
    }

    private handleToggle = () => {
      if (!this.details) return
      if (this.details.open) {
        document.body.classList.add('menu-open')
        const firstLink = this.details.querySelector('.mobile-nav-link') as HTMLElement | null
        if (firstLink) setTimeout(() => firstLink.focus(), 50)
      } else {
        document.body.classList.remove('menu-open')
      }
    }

    private close() {
      if (!this.details) return
      this.details.open = false
    }

    cleanup() {
      this.abortController?.abort()
      this.abortController = null
      document.body.classList.remove('menu-open')
    }
  }

  let menuInstance: MobileMenu | null = null

  function initMenu() {
    menuInstance?.cleanup()
    menuInstance = new MobileMenu()
  }

  document.addEventListener('astro:page-load', initMenu)
  document.addEventListener('astro:before-swap', () => {
    menuInstance?.cleanup()
  })
</script>
