---
interface Props {
  currentPath: string
}

const { currentPath } = Astro.props

const navItems = [
  { label: 'Index', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'Writing', href: '/writing' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
]

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/'
  return current.startsWith(href)
}
---

<header class="nav-header" id="nav-header">
  <nav class="nav-container" aria-label="Primary">
    <a href="/" class="nav-mark" aria-label="Home">
      <span class="nav-mark-dot" aria-hidden="true"></span>
      <span class="nav-mark-name">Chris Lacey</span>
    </a>

    <!-- Desktop navigation -->
    <ul class="nav-desktop" role="list">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { active: isActive(item.href, currentPath) }]}
              aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
              data-astro-prefetch="viewport"
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <button
          type="button"
          class="theme-btn"
          id="theme-btn"
          aria-label="Toggle color theme"
          data-theme-label
        >
          moon
        </button>
      </li>
      <li class="nav-underline-slot" aria-hidden="true">
        <span class="nav-underline" id="nav-underline"></span>
      </li>
    </ul>

    <!-- Mobile: native <details>/<summary> baseline, progressively enhanced -->
    <details class="mobile-menu" id="mobile-menu">
      <summary class="hamburger" aria-label="Menu">
        <span class="sr-only">Menu</span>
        <span class="hamburger-icon" aria-hidden="true">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </span>
      </summary>

      <div class="mobile-overlay">
        <ul class="mobile-nav-list" role="list">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={['mobile-nav-link', { active: isActive(item.href, currentPath) }]}
                  aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
                  data-astro-prefetch="viewport"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <button
              type="button"
              class="mobile-theme-btn"
              id="mobile-theme-btn"
              aria-label="Toggle color theme"
              data-theme-label
            >
              moon
            </button>
          </li>
        </ul>
      </div>
    </details>
  </nav>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(14px);
    background: color-mix(in oklab, var(--color-background) 78%, transparent);
    border-bottom: 1px solid var(--color-rule);
  }

  .nav-container {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px clamp(24px, 5vw, 80px);
  }

  .nav-mark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-foreground);
    text-decoration: none;
  }

  .nav-mark-dot {
    display: block;
    width: 10px;
    height: 10px;
    background: var(--color-accent);
  }

  .nav-mark-name {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: inherit;
  }

  /* Desktop navigation */
  .nav-desktop {
    display: none;
    list-style: none;
    gap: 28px;
    align-items: center;
    margin: 0;
    padding: 0;
    position: relative;
  }

  .nav-underline-slot {
    position: static;
    width: 0;
    height: 0;
    padding: 0;
    margin: 0;
  }

  .nav-underline {
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transform: translateX(0);
    pointer-events: none;
    opacity: 0;
    transition:
      transform 0.25s ease,
      width 0.25s ease;
  }

  .nav-underline.is-ready {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    position: relative;
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-foreground);
  }

  .theme-btn {
    background: none;
    border: 1px solid var(--color-rule);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 6px 10px;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .theme-btn:hover {
    color: var(--color-foreground);
    border-color: var(--color-rule-strong);
  }

  /* Mobile menu — <details>/<summary> baseline */
  .mobile-menu {
    display: block;
  }

  @media (min-width: 768px) {
    .mobile-menu {
      display: none;
    }
  }

  .mobile-menu > summary {
    list-style: none;
  }

  .mobile-menu > summary::-webkit-details-marker {
    display: none;
  }

  .hamburger {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    touch-action: manipulation;
  }

  .hamburger-icon {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 24px;
    height: 18px;
    gap: 6px;
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-foreground);
    transition: transform 0.2s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  .mobile-menu[open] .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .mobile-menu[open] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu[open] .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 6rem 2rem 4rem;
    background: var(--color-background);
    overflow-y: auto;
  }

  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mobile-nav-link {
    display: block;
    padding: 1.25rem 0;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 7vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
  }

  .mobile-nav-link.active {
    color: var(--color-accent);
  }

  .mobile-theme-btn {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 10px 16px;
    background: none;
    border: 1px solid var(--color-rule);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    cursor: pointer;
  }

  :global(body.menu-open) {
    overflow: hidden;
    touch-action: none;
    overscroll-behavior: none;
  }
</style>

<script>
  // Progressive enhancement for the native <details>/<summary> baseline.
  // The menu is fully usable without this script — it just improves focus
  // handling, body scroll lock, and keyboard close behavior.
  class MobileMenu {
    private details: HTMLDetailsElement | null = null
    private abortController: AbortController | null = null

    constructor() {
      this.init()
    }

    private init() {
      this.cleanup()
      this.details = document.getElementById('mobile-menu') as HTMLDetailsElement | null
      if (!this.details) return

      this.abortController = new AbortController()
      const { signal } = this.abortController

      this.details.addEventListener('toggle', this.handleToggle, { signal })

      document.addEventListener(
        'keydown',
        (e: KeyboardEvent) => {
          if (e.key === 'Escape' && this.details?.open) {
            this.close()
          }
        },
        { signal },
      )
    }

    private handleToggle = () => {
      if (!this.details) return
      if (this.details.open) {
        document.body.classList.add('menu-open')
        const firstLink = this.details.querySelector('.mobile-nav-link') as HTMLElement | null
        if (firstLink) setTimeout(() => firstLink.focus(), 50)
      } else {
        document.body.classList.remove('menu-open')
      }
    }

    private close() {
      if (!this.details) return
      this.details.open = false
    }

    cleanup() {
      this.abortController?.abort()
      this.abortController = null
      document.body.classList.remove('menu-open')
    }
  }

  let menuInstance: MobileMenu | null = null

  function initMenu() {
    menuInstance?.cleanup()
    menuInstance = new MobileMenu()
  }

  // Theme toggle — reads stored preference (or system) and exposes a click
  // handler on any element with [data-theme-label]. Button label mirrors the
  // action: "moon" when currently light, "sun" when currently dark.
  function applyTheme(theme: 'light' | 'dark') {
    document.documentElement.setAttribute('data-theme', theme)
    try {
      localStorage.setItem('cl-theme', theme)
    } catch {}
    for (const el of document.querySelectorAll<HTMLElement>('[data-theme-label]')) {
      el.textContent = theme === 'dark' ? 'sun' : 'moon'
    }
  }

  function currentTheme(): 'light' | 'dark' {
    const attr = document.documentElement.getAttribute('data-theme')
    return attr === 'dark' ? 'dark' : 'light'
  }

  function initThemeButtons() {
    applyTheme(currentTheme())
    for (const el of document.querySelectorAll<HTMLButtonElement>('[data-theme-label]')) {
      el.addEventListener('click', () => {
        applyTheme(currentTheme() === 'dark' ? 'light' : 'dark')
      })
    }
  }

  function syncActiveNav() {
    const path = window.location.pathname
    const isActive = (href: string) => {
      if (href === '/') return path === '/'
      return path.startsWith(href)
    }
    const selector = '.nav-link[href], .mobile-nav-link[href]'
    for (const link of document.querySelectorAll<HTMLAnchorElement>(selector)) {
      const href = link.getAttribute('href') ?? ''
      const active = isActive(href)
      link.classList.toggle('active', active)
      if (active) {
        link.setAttribute('aria-current', 'page')
      } else {
        link.removeAttribute('aria-current')
      }
    }
  }

  // Single shared underline slides between active tabs instead of each
  // tab rendering its own ::after. Positioning is relative to the
  // `.nav-desktop` <ul>, which has `position: relative`, so we can use
  // each link's offsetLeft/offsetWidth directly.
  function positionUnderline(target?: HTMLAnchorElement | null, animate = true) {
    const underline = document.getElementById('nav-underline') as HTMLElement | null
    if (!underline) return
    const active =
      target ??
      (document.querySelector('.nav-desktop .nav-link.active') as HTMLAnchorElement | null)
    if (!active) {
      underline.classList.remove('is-ready')
      underline.style.width = '0px'
      return
    }
    const apply = () => {
      underline.style.transform = `translateX(${active.offsetLeft}px)`
      underline.style.width = `${active.offsetWidth}px`
      underline.classList.add('is-ready')
    }
    if (animate) {
      apply()
    } else {
      // First paint or resize — skip the transition so we don't animate
      // from (0,0) or between old and new resized positions.
      const prev = underline.style.transition
      underline.style.transition = 'none'
      apply()
      // Force reflow so the no-transition state applies before we restore.
      void underline.offsetWidth
      underline.style.transition = prev
    }
  }

  let underlineResizeBound = false
  function bindUnderlineResize() {
    if (underlineResizeBound) return
    underlineResizeBound = true
    window.addEventListener('resize', () => positionUnderline(undefined, false))
  }

  function init() {
    initMenu()
    initThemeButtons()
    syncActiveNav()
    bindUnderlineResize()
    positionUnderline(undefined, false)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true })
  } else {
    init()
  }
</script>
