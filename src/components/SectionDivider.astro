---
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<div class:list={['section-divider', className]} aria-hidden="true" transition:name="section-divider"></div>

<style>
  .section-divider {
    width: 100%;
    height: 1px;
    margin: 3rem 0;
    background: var(--color-rule);
  }
</style>
