---
import SiteFooter from '../components/SiteFooter.astro'
import homeData from '../data/home.json'
import { leadProjects } from '../data/projects'
import BaseLayout from '../layouts/BaseLayout.astro'

const { hero, now } = homeData
---

<BaseLayout title="Chris Lacey — full-stack AI product engineer">
  <div class="cl-page">
    <!-- Editorial hero -->
    <section class="hero">
      <div class="hero-kicker mono">{hero.kicker}</div>
      <h1 class="hero-name">
        Full-stack AI<br />product engineer<span class="hero-accent">.</span>
      </h1>
      <p class="hero-thesis serif">
        <em>{hero.thesis}</em>
      </p>
      {/* Availability strip — temporarily hidden while showing the site in
          professional contexts. Restore when publicly signaling availability. */}
      {/*
      <div class="hero-foot">
        <div class="avail" aria-label="Availability">
          <span class="avail-dot" aria-hidden="true"></span>
          <span>{hero.availability.status}</span>
          <span class="avail-sep" aria-hidden="true">·</span>
          <span>{hero.availability.location}</span>
        </div>
        <div class="hero-avail mono">{hero.availability.focus}</div>
      </div>
      */}
    </section>

    <!-- Evidence of method -->
    <section class="section-evidence">
      <div class="rule"><span class="rule-label">Evidence of method</span></div>
      <div class="evidence-grid">
        {
          leadProjects.map((p, i) => (
            <a href={`/projects/${p.id}`} class="evidence-item">
              <div class="evidence-head">
                <span class="mono mono-tiny muted">0{i + 1}</span>
                <span class="mono mono-tiny muted">
                  {p.year} · {p.kicker}
                </span>
              </div>
              <h3 class="evidence-title">{p.title}</h3>
              <p class="evidence-blurb serif">{p.blurb}</p>
              <div class="evidence-link mono">
                <span>Read the move</span>
                <span class="arrow">→</span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- /now -->
    <section class="section-now">
      <div class="rule"><span class="rule-label">/now</span></div>
      <div class="now-grid">
        <div class="now-lede serif">
          Three things true of <em>this week</em>, not six months ago.
        </div>
        <ul class="now-list">
          {
            now.map((n) => (
              <li class="now-item">
                <span class="mono mono-tiny muted">{n.date}</span>
                <span>{n.text}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .cl-page {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 80px) 120px;
  }

  /* Hero */
  .hero {
    padding: clamp(56px, 12vw, 140px) 0 clamp(64px, 10vw, 120px);
    position: relative;
  }

  .hero-kicker {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 128px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    font-weight: 500;
    margin: 22px 0 0;
    max-width: 16ch;
    color: var(--color-foreground);
  }

  .hero-accent {
    color: var(--color-accent);
  }

  .hero-thesis {
    font-size: clamp(22px, 2.4vw, 34px);
    line-height: 1.35;
    margin: 40px 0 0;
    max-width: 28ch;
    font-weight: 400;
  }

  .hero-foot {
    margin-top: 72px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px 32px;
    align-items: center;
    padding-top: 28px;
    border-top: 1px solid var(--color-rule);
  }

  .avail {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  .avail-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--color-confidence);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--color-confidence) 28%, transparent);
    animation: cl-pulse 2.4s ease-in-out infinite;
  }

  .avail-sep {
    color: var(--color-muted-2);
  }

  @keyframes cl-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 3px
        color-mix(in srgb, var(--color-confidence) 28%, transparent);
    }
    50% {
      box-shadow: 0 0 0 6px
        color-mix(in srgb, var(--color-confidence) 10%, transparent);
    }
  }

  .hero-avail {
    font-size: 12px;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  /* Rule */
  .rule {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: clamp(56px, 9vw, 120px) 0 32px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .rule::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--color-foreground);
  }

  .rule::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-rule);
  }

  .rule-label {
    white-space: nowrap;
  }

  /* Evidence strip */
  .evidence-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--color-rule);
  }

  @media (max-width: 900px) {
    .evidence-grid {
      grid-template-columns: 1fr;
    }
  }

  .evidence-item {
    padding: 32px 24px 28px;
    border-right: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    transition: background 0.25s ease;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .evidence-item:last-child {
    border-right: none;
  }

  @media (max-width: 900px) {
    .evidence-item {
      border-right: none;
    }
  }

  .evidence-item:hover {
    background: var(--color-tint);
  }

  .evidence-item:hover .arrow {
    transform: translateX(6px);
    color: var(--color-accent);
  }

  .evidence-head {
    display: flex;
    justify-content: space-between;
  }

  .mono-tiny {
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .muted {
    color: var(--color-muted);
  }

  .evidence-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .evidence-blurb {
    font-size: 17px;
    line-height: 1.5;
    margin: 0;
    color: var(--color-foreground);
  }

  .evidence-link {
    margin-top: auto;
    padding-top: 16px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .arrow {
    display: inline-block;
    transition: transform 0.25s ease, color 0.2s ease;
  }

  /* Now */
  .now-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 48px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .now-grid {
      grid-template-columns: 1fr;
    }
  }

  .now-lede {
    font-size: 24px;
    line-height: 1.4;
    color: var(--color-foreground);
  }

  .now-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .now-item {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 24px;
    align-items: baseline;
    padding: 20px 0;
    border-bottom: 1px solid var(--color-rule);
    font-size: 17px;
    line-height: 1.45;
    font-family: var(--font-serif);
  }

  .now-item:first-child {
    border-top: 1px solid var(--color-rule);
  }
</style>
