---
import { Image } from 'astro:assets'
import headshot from '../assets/headshot.jpeg'
import InteractiveSkillIcon from '../components/InteractiveSkillIcon.astro'
import ProjectCard from '../components/ProjectCard.astro'
import SectionDivider from '../components/SectionDivider.astro'
import homeData from '../data/home.json'
import { leadProjects } from '../data/projects'
import BaseLayout from '../layouts/BaseLayout.astro'

const { hero, skills } = homeData
---

<BaseLayout title="Chris Lacey | Full-stack AI product engineer">
  <div class="min-h-[calc(100vh-60px)]">
    <div class="relative mx-auto max-w-7xl px-6 py-12 md:px-12 md:py-20 lg:py-24 space-y-20">
      <!-- Hero Section -->
      <section class="hero">
        <div class="hero-grid" transition:name="intro-text">
          <!-- Left Column: Avatar -->
          <div class="hero-avatar">
            <Image
              src={headshot}
              alt={`Portrait of ${hero.name}`}
              class="hero-avatar-img"
              width={288}
              height={288}
              loading="eager"
            />
          </div>

          <!-- Right Column: Text Content -->
          <div class="hero-text">
            <h1 class="hero-name" transition:name="page-title">
              {hero.name}
            </h1>
            <p class="hero-role">{hero.role}</p>

            <p class="hero-lede">{hero.lede}</p>

            <p class="hero-availability" aria-label="Availability">
              <span class="hero-availability-status">{hero.availability.status}</span>
              <span class="hero-availability-sep" aria-hidden="true">·</span>
              <span>{hero.availability.focus}</span>
            </p>

            <!-- CTA Buttons -->
            <div class="hero-ctas">
              {hero.ctas.map((cta) => (
                <a
                  href={cta.href}
                  download={cta.download}
                  data-variant={cta.variant === 'primary' ? 'primary' : 'secondary'}
                  class="cta-link"
                >
                  {cta.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <SectionDivider />

      <div class="space-y-12" transition:name="main-content">
        <!-- Skills Section -->
        <section class="stack-section" aria-labelledby="skills-heading">
          <h2 id="skills-heading" class="stack-label">Stack</h2>

          <div class="stack-grid">
            {skills.map((skill) => (
              <InteractiveSkillIcon icon={skill.icon} name={skill.name} />
            ))}
          </div>
        </section>

        <!-- Selected Projects Section -->
        <section class="space-y-6" aria-labelledby="projects-heading">
          <div class="flex items-center justify-between">
            <h2 id="projects-heading" class="text-sm font-semibold tracking-widest uppercase text-[color:var(--color-muted)]">Selected Projects</h2>
            <a
              href="/projects"
              class="projects-link group flex items-center gap-2 text-sm font-medium"
            >
              View all projects
              <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {leadProjects.map((project) => (
              <ProjectCard
                href={`/projects/${project.id}`}
                title={project.title}
                description={project.blurb}
                imageSrc={project.image}
                imageAlt={project.imageAlt}
                id={project.id}
              />
            ))}
          </div>
        </section>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    justify-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: auto 1fr;
      gap: 3rem;
      justify-items: start;
      text-align: left;
      align-items: start;
    }
  }

  @media (min-width: 1024px) {
    .hero-grid {
      gap: 4rem;
    }
  }

  .hero-avatar {
    width: 10rem;
    height: 10rem;
  }

  @media (min-width: 768px) {
    .hero-avatar {
      width: 14rem;
      height: 14rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-avatar {
      width: 16rem;
      height: 16rem;
    }
  }

  .hero-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 9999px;
    border: 1px solid var(--color-rule);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    max-width: 42rem;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
    color: var(--color-foreground);
  }

  .hero-role {
    font-family: var(--font-display);
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    font-weight: 500;
    letter-spacing: 0.005em;
    color: var(--color-forest-floor);
    margin: 0.5rem 0 0;
  }

  .hero-lede {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin: 2rem 0 0;
    max-width: 34rem;
  }

  .hero-availability {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin: 2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 0.6rem;
  }

  @media (min-width: 768px) {
    .hero-availability {
      justify-content: flex-start;
    }
  }

  .hero-availability-status {
    color: var(--color-forest-floor);
    position: relative;
    padding-left: 1rem;
  }

  .hero-availability-status::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: var(--color-confidence);
  }

  .hero-availability-sep {
    color: var(--color-rule);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-ctas {
      justify-content: flex-start;
    }
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .cta-link[data-variant="primary"] {
    background: var(--color-accent);
    color: var(--color-legal-pad);
    border-color: var(--color-accent);
  }

  .cta-link[data-variant="primary"]:hover {
    background: var(--color-ink-well);
    border-color: var(--color-ink-well);
  }

  .cta-link[data-variant="secondary"] {
    background: transparent;
    color: var(--color-foreground);
    border-color: var(--color-foreground);
  }

  .cta-link[data-variant="secondary"]:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .projects-link {
    color: var(--color-foreground);
    transition: color 0.2s ease;
  }

  .projects-link:hover {
    color: var(--color-accent);
  }

  .stack-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .stack-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-forest-floor);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    text-align: center;
  }

  @media (min-width: 768px) {
    .stack-label {
      text-align: left;
    }
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    justify-items: center;
  }

  @media (min-width: 480px) {
    .stack-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 768px) {
    .stack-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .stack-grid {
      grid-template-columns: repeat(9, 1fr);
    }
  }
</style>
