---
import SiteFooter from '../components/SiteFooter.astro'
import contactData from '../data/contact.json'
import BaseLayout from '../layouts/BaseLayout.astro'

const { intro, links } = contactData

function displayValue(link: (typeof links)[number]): string {
  if (link.icon === 'email') return 'chrislacey89@gmail.com'
  return link.href.replace(/^https?:\/\//, '').replace(/\/$/, '')
}
---

<BaseLayout title="Contact | Chris Lacey" description="Get in touch with Chris Lacey.">
  <div class="cl-page">
    <header class="page-head">
      <div class="mono mono-tiny muted">Contact · replies in two business days</div>
      <h1 class="page-title serif" transition:name="page-lede">Say the specific thing.</h1>
      <p class="page-sub serif">{intro}</p>
    </header>

    <section class="contact-body">
      <ul class="contact-list">
        {
          links.map((link, i) => {
            const isExternal = link.icon !== 'email'
            return (
              <li class="contact-row">
                <span class="mono mono-tiny muted">0{i + 1}</span>
                <span class="mono contact-label">{link.label}</span>
                <a
                  class="mono contact-value"
                  href={link.href}
                  target={isExternal ? '_blank' : undefined}
                  rel={isExternal ? 'noopener noreferrer' : undefined}
                >
                  {displayValue(link)} <span class="accent" aria-hidden="true">↗</span>
                  {isExternal && <span class="sr-only"> (opens in new tab)</span>}
                </a>
              </li>
            )
          })
        }
      </ul>
      <p class="contact-note serif">
        <em>Sent.</em> I'll respond within two business days.
      </p>
    </section>

    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .cl-page {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 80px) 120px;
  }

  .page-head {
    padding: clamp(56px, 10vw, 120px) 0 48px;
  }

  .mono-tiny {
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .muted {
    color: var(--color-muted);
  }

  .accent {
    color: var(--color-accent);
    font-style: normal;
    font-weight: 500;
  }

  .page-title {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 500;
    margin: 16px 0 0;
    max-width: 22ch;
    color: var(--color-foreground);
  }

  .page-sub {
    font-size: 22px;
    line-height: 1.5;
    margin: 24px 0 0;
    max-width: 60ch;
    color: var(--color-foreground);
  }

  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-foreground);
  }

  .contact-row {
    display: grid;
    grid-template-columns: 60px 120px 1fr;
    gap: 24px;
    align-items: baseline;
    padding: 20px 0;
    border-bottom: 1px solid var(--color-rule);
    font-size: 15px;
  }

  @media (max-width: 640px) {
    .contact-row {
      grid-template-columns: 80px 1fr;
    }

    .contact-row > .mono-tiny {
      display: none;
    }
  }

  .contact-label {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 11px;
    color: var(--color-muted);
  }

  .contact-value {
    text-decoration: none;
    color: var(--color-foreground);
    transition: color 0.2s ease;
  }

  .contact-value:hover {
    color: var(--color-accent);
  }

  .contact-note {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--color-rule);
    font-size: 20px;
    color: var(--color-muted);
    font-style: italic;
  }
</style>
