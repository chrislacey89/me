---
import { Image } from 'astro:assets'
import SiteFooter from '../../components/SiteFooter.astro'
import { type LeadProject, leadProjects } from '../../data/projects'
import BaseLayout from '../../layouts/BaseLayout.astro'

export function getStaticPaths() {
  return leadProjects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }))
}

const { project } = Astro.props as { project: LeadProject }
const { detail } = project
const idx = leadProjects.findIndex((p) => p.id === project.id)
const next = leadProjects[(idx + 1) % leadProjects.length]

// Supports author-controlled inline markdown: `[label](url)` links (http/https or
// root-relative only) and `` `code` `` chips. Inputs come from typed data in
// src/data/projects.ts — no user-generated content passes through here.
function renderInlineMarkdown(text: string): string {
  const escaped = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  return escaped
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_match, label: string, url: string) => {
      if (!/^(https?:\/\/|\/)/.test(url)) return label
      return `<a href="${url}" target="_blank" rel="noopener noreferrer">${label}</a>`
    })
    .replace(/`([^`]+)`/g, '<code>$1</code>')
}

const repoLink = project.github || project.liveUrl
const repoDisplay = repoLink?.replace(/^https?:\/\//, '').replace(/\/$/, '')
---

<BaseLayout title={`${project.title} | Chris Lacey`} description={project.blurb}>
  <article class="cl-page cl-detail">
    <a href="/projects" class="back">
      <span class="arrow arrow-back">←</span> All projects
    </a>

    <header class="detail-head">
      <div class="detail-meta mono">
        <span>0{idx + 1} · Lead</span>
        <span class="dot-sep">·</span>
        <span>{project.year}</span>
        <span class="dot-sep">·</span>
        <span class="accent">{project.kicker}</span>
      </div>
      <h1 class="detail-title" transition:name={`project-title-${project.id}`}>{project.title}</h1>
      <p class="detail-claim serif">{detail.claim}</p>
    </header>

    <div class="detail-body">
      <div class="detail-col">
        {project.image && (
          <div class="detail-image" transition:name={`project-image-${project.id}`}>
            <Image
              src={project.image}
              alt={project.imageAlt ?? ''}
              widths={[640, 1280]}
              sizes="(min-width: 900px) 640px, 100vw"
              quality={88}
              priority
            />
          </div>
        )}

        <section class="section">
          <div class="section-label mono">Context</div>
          <div class="section-body">
            <p class="serif" set:html={renderInlineMarkdown(detail.context)}></p>
          </div>
        </section>

        <section class="section is-accent" transition:name={`project-section-move-${project.id}`}>
          <div class="section-label mono">The move</div>
          <div class="section-body">
            <p class="serif move" set:html={renderInlineMarkdown(detail.move)}></p>
          </div>
        </section>

        <section class="section" transition:name={`project-section-artifact-${project.id}`}>
          <div class="section-label mono">The artifact</div>
          <div class="section-body">
            <p class="serif" set:html={renderInlineMarkdown(detail.artifact)}></p>
          </div>
        </section>

        <section class="section" transition:name={`project-section-cost-${project.id}`}>
          <div class="section-label mono">Cost / return</div>
          <div class="section-body">
            <p class="serif" set:html={renderInlineMarkdown(detail.costReturn)}></p>
          </div>
        </section>

        <blockquote class="pullquote">
          <span class="pullquote-mark" aria-hidden="true">“</span>
          <span class="serif">{detail.pullQuote}</span>
        </blockquote>
      </div>

      <aside class="detail-side">
        <div class="side-card" transition:name={`project-section-receipts-${project.id}`}>
          <div class="mono mono-tiny muted side-label">Receipts</div>
          <ul class="receipts">
            {detail.receipts.map((r) => (
              <li class="mono" set:html={renderInlineMarkdown(r)} />
            ))}
          </ul>
          {repoLink && (
            <div class="side-link mono">
              <a href={repoLink} target="_blank" rel="noopener noreferrer">
                <span class="accent">→</span> {repoDisplay}
              </a>
            </div>
          )}
        </div>
        <div class="side-card">
          <div class="mono mono-tiny muted side-label">Metadata</div>
          <div class="mono side-row">
            <span>shipped</span><span>{project.year}</span>
          </div>
          <div class="mono side-row">
            <span>role</span><span>sole developer</span>
          </div>
          <div class="mono side-row">
            <span>status</span><span class="confidence">● in use</span>
          </div>
        </div>
      </aside>
    </div>

    <section class="next-project">
      <div class="rule"><span class="rule-label">Next</span></div>
      <a class="next" href={`/projects/${next.id}`}>
        <div>
          <div class="mono mono-tiny muted">Next · {next.kicker}</div>
          <div class="next-title">{next.title}</div>
          <div class="serif next-claim">{next.detail.claim}</div>
        </div>
        <span class="arrow-xl">→</span>
      </a>
    </section>

    <SiteFooter />
  </article>
</BaseLayout>

<style>
  .cl-page {
    max-width: 80rem;
    margin: 0 auto;
    padding: 24px clamp(24px, 5vw, 80px) 120px;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    text-decoration: none;
    margin-top: 24px;
  }

  .back:hover {
    color: var(--color-accent);
  }

  .arrow-back {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .back:hover .arrow-back {
    transform: translateX(-6px);
  }

  .detail-head {
    padding: 40px 0 48px;
    border-bottom: 1px solid var(--color-foreground);
  }

  .detail-meta {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .dot-sep {
    color: var(--color-muted-2);
  }

  .accent {
    color: var(--color-accent);
  }

  .mono-tiny {
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .muted {
    color: var(--color-muted);
  }

  .confidence {
    color: var(--color-confidence) !important;
  }

  .detail-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 120px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    font-weight: 500;
    margin: 16px 0 0;
    color: var(--color-foreground);
    view-transition-class: project-title;
  }

  .detail-claim {
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.35;
    margin: 28px 0 0;
    max-width: 32ch;
    font-style: italic;
  }

  .detail-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 64px;
    padding-top: 56px;
  }

  @media (max-width: 900px) {
    .detail-body {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .detail-col {
    min-width: 0;
  }

  .detail-image {
    margin-bottom: 16px;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border: 1px solid var(--color-rule);
    view-transition-class: project-image;
  }

  .detail-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Section */
  .section {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 32px;
    padding: 32px 0;
    border-bottom: 1px solid var(--color-rule);
    align-items: start;
    view-transition-class: project-section;
  }

  @media (max-width: 700px) {
    .section {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .section-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding-top: 8px;
  }

  .section.is-accent .section-label {
    color: var(--color-accent);
  }

  .section-body p.serif {
    font-size: 19px;
    line-height: 1.55;
    margin: 0;
    color: var(--color-foreground);
  }

  .section-body p.serif + p.serif {
    margin-top: 16px;
  }

  .section-body .move {
    border-left: 2px solid var(--color-accent);
    padding-left: 20px;
    font-size: 20px;
  }

  .section-body :global(a) {
    color: var(--color-forest-floor);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .section-body :global(a:hover) {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .section-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-foreground);
    background: var(--color-tint);
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }

  /* Pullquote */
  .pullquote {
    margin: 48px 0 0;
    padding: 32px 0 0;
    border-top: 1px solid var(--color-rule);
    position: relative;
  }

  .pullquote-mark {
    position: absolute;
    top: 6px;
    left: -4px;
    font-family: var(--font-serif);
    font-size: 64px;
    color: var(--color-accent);
    line-height: 0.8;
  }

  .pullquote .serif {
    display: block;
    padding-left: 40px;
    font-size: 32px;
    line-height: 1.3;
    font-weight: 500;
  }

  /* Side */
  .detail-side {
    position: sticky;
    top: 96px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (max-width: 900px) {
    .detail-side {
      position: static;
    }
  }

  .side-card {
    border: 1px solid var(--color-rule);
    padding: 20px;
    background: var(--color-tint);
  }

  .side-label {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    display: block;
    margin-bottom: 12px;
  }

  .receipts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .receipts li {
    font-size: 12px;
    line-height: 1.5;
    padding: 8px 0;
    border-bottom: 1px dashed var(--color-rule);
    color: var(--color-foreground);
  }

  .receipts li:last-child {
    border-bottom: none;
  }

  .receipts :global(a) {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
  }

  .receipts :global(a:hover) {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .side-link {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--color-rule);
    font-size: 12px;
  }

  .side-link a {
    color: var(--color-foreground);
    text-decoration: none;
  }

  .side-link a:hover {
    color: var(--color-accent);
  }

  .side-row {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    padding: 8px 0;
    letter-spacing: 0.04em;
    color: var(--color-muted);
  }

  .side-row span:last-child {
    color: var(--color-foreground);
  }

  /* Next */
  .next-project {
    margin-top: 64px;
  }

  .rule {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: clamp(56px, 9vw, 120px) 0 32px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .rule::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--color-foreground);
  }

  .rule::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-rule);
  }

  .rule-label {
    white-space: nowrap;
  }

  .next {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 40px 0;
    border-top: 1px solid var(--color-foreground);
    border-bottom: 1px solid var(--color-foreground);
    text-decoration: none;
    color: var(--color-foreground);
    transition: padding 0.25s ease;
  }

  .next:hover {
    padding-left: 12px;
  }

  .next:hover .arrow-xl {
    transform: translateX(12px);
    color: var(--color-accent);
  }

  .next-title {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-top: 8px;
  }

  .next-claim {
    font-size: 18px;
    line-height: 1.4;
    margin-top: 8px;
    max-width: 48ch;
    color: var(--color-muted);
  }

  .arrow-xl {
    font-size: 56px;
    transition: transform 0.25s ease, color 0.2s ease;
  }
</style>
