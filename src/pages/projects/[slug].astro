---
import { Image } from 'astro:assets'
import { type LeadProject, leadProjects } from '../../data/projects'
import BaseLayout from '../../layouts/BaseLayout.astro'

export function getStaticPaths() {
  return leadProjects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }))
}

const { project } = Astro.props as { project: LeadProject }
const { detail } = project

// Supports author-controlled inline markdown: `[label](url)` links (http/https or
// root-relative only) and `` `code` `` chips. Inputs come from typed data in
// src/data/projects.ts — no user-generated content passes through here.
function renderInlineMarkdown(text: string): string {
  const escaped = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  return escaped
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_match, label: string, url: string) => {
      if (!/^(https?:\/\/|\/)/.test(url)) return label
      return `<a href="${url}" target="_blank" rel="noopener noreferrer">${label}</a>`
    })
    .replace(/`([^`]+)`/g, '<code>$1</code>')
}
---

<BaseLayout title={`${project.title} | Chris Lacey`} description={project.blurb}>
  <article class="project">
    <a href="/projects" class="back-link">← Projects</a>

    <header class="project-header">
      {project.image && (
        <div class="project-image" transition:name={`project-image-${project.id}`}>
          <Image
            src={project.image}
            alt={project.imageAlt ?? ''}
            widths={[500, 800, 1100, 1400, 1800]}
            sizes="(min-width: 768px) 704px, 100vw"
            width={1800}
            height={1012}
            quality={90}
          />
        </div>
      )}
      <p class="section-label">Claim</p>
      <h1 class="claim" transition:name={`project-title-${project.id}`}>{detail.claim}</h1>
    </header>

    <section class="section">
      <h2 class="section-label">Context</h2>
      <p class="prose" set:html={renderInlineMarkdown(detail.context)}></p>
    </section>

    <section class="section section--move">
      <h2 class="section-label">The move</h2>
      <p class="prose prose--lead" set:html={renderInlineMarkdown(detail.move)}></p>
    </section>

    <section class="section">
      <h2 class="section-label">Artifact</h2>
      <p class="prose" set:html={renderInlineMarkdown(detail.artifact)}></p>
    </section>

    <section class="section">
      <h2 class="section-label">Cost / return</h2>
      <p class="prose" set:html={renderInlineMarkdown(detail.costReturn)}></p>
    </section>

    <section class="section">
      <h2 class="section-label">Receipts</h2>
      <ul class="receipts">
        {detail.receipts.map((line) => <li set:html={renderInlineMarkdown(line)}></li>)}
      </ul>
      {(project.github || project.liveUrl) && (
        <ul class="receipts receipts--links">
          {project.github && (
            <li>
              <a href={project.github} target="_blank" rel="noopener noreferrer">
                {project.github.replace(/^https?:\/\//, '')}
              </a>
            </li>
          )}
          {project.liveUrl && (
            <li>
              <a href={project.liveUrl} target="_blank" rel="noopener noreferrer">
                {project.liveUrl.replace(/^https?:\/\//, '').replace(/\/$/, '')}
              </a>
            </li>
          )}
        </ul>
      )}
    </section>

    <aside class="pull-quote">
      <p>{detail.pullQuote}</p>
    </aside>
  </article>
</BaseLayout>

<style>
  .project {
    max-width: 44rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    color: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .project {
      padding: 4.5rem 2rem 8rem;
    }
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .project-header {
    margin-bottom: 3.5rem;
  }

  .project-image {
    aspect-ratio: 16 / 9;
    margin-bottom: 2.5rem;
    overflow: hidden;
    border: 1px solid var(--color-rule);
    view-transition-class: project-image;
  }

  .project-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-forest-floor);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }

  .claim {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
    margin: 0;
  }

  .section {
    margin-top: 3rem;
  }

  .section--move {
    padding: 2rem 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }

  .prose {
    font-family: var(--font-display);
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-foreground);
    margin: 0;
    max-width: 65ch;
  }

  .prose--lead {
    font-size: 1.25rem;
    line-height: 1.6;
  }

  .prose :global(code),
  .receipts :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-foreground);
    background: rgba(47, 93, 80, 0.12);
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }

  .prose :global(a) {
    color: var(--color-forest-floor);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    transition:
      border-bottom-color 0.15s ease,
      color 0.15s ease;
  }

  .prose :global(a:hover) {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .prose :global(a code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .receipts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-foreground);
  }

  .receipts li {
    padding-left: 1rem;
    position: relative;
  }

  .receipts li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-forest-floor);
  }

  .receipts--links {
    margin-top: 1rem;
  }

  .receipts--links a {
    color: var(--color-forest-floor);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
  }

  .receipts--links a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .pull-quote {
    margin: 4rem 0 0;
    padding: 2rem 0 0;
    border-top: 1px solid var(--color-rule);
  }

  .pull-quote p {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-accent);
    margin: 0;
    max-width: 38ch;
  }
</style>
