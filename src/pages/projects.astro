---
import ProjectCard from '../components/ProjectCard.astro'
import SectionDivider from '../components/SectionDivider.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import type { ImageMetadata } from 'astro'
import projectsData from '../data/projects.json'
import contentToSkillImage from '../assets/projects/content-to-skill.png'
import fulcrumImage from '../assets/projects/fulcrum.png'
import mikelaceySiteImage from '../assets/projects/mikelacey-site.png'
import empowermentBriefImage from '../assets/projects/empowerment-brief.png'

const { projects } = projectsData

const projectImages: Record<string, ImageMetadata> = {
  'fulcrum': fulcrumImage,
  'content-to-skill': contentToSkillImage,
  'mikelacey-site': mikelaceySiteImage,
  'empowerment-brief': empowermentBriefImage,
}
---

<BaseLayout title="Projects | Chris Lacey" description="Case studies showcasing technical work with context on architecture decisions and tradeoffs.">
  <div class="min-h-[calc(100vh-60px)] text-white selection:bg-teal-400/30 selection:text-teal-200">
    <div class="relative mx-auto max-w-7xl px-6 py-12 md:px-12 md:py-20 lg:py-24">
      <!-- Page Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold md:text-5xl gradient-heading" transition:name="page-title">Projects</h1>
      </div>

      <!-- Intro -->
      <p class="text-lg leading-relaxed text-text-muted-light max-w-2xl" transition:name="intro-text">
        Case studies showcasing technical work with context on architecture decisions and tradeoffs.
      </p>

      <SectionDivider class="my-12" />

      <!-- Projects Grid -->
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal-group>
        {projects.map((project, index) => (
          <ProjectCard
            href={`/projects/${project.id}`}
            title={project.title}
            description={project.description}
            comingSoon={!project.caseStudy}
            imageSrc={projectImages[project.id]}
            id={project.id}
            class="reveal-scale"
            data-reveal-delay={index * 100}
          />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
