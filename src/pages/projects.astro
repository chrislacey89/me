---
import ProjectCard from '../components/ProjectCard.astro'
import { leadProjects, supportingProjects } from '../data/projects'
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Projects | Chris Lacey"
  description="Three lead projects and a supporting strip — each case study frames the claim, the move, and what it cost."
>
  <div class="projects-page">
    <header class="page-header">
      <p class="eyebrow">Projects</p>
      <h1 class="lede" transition:name="page-lede">Three lead projects, one supporting strip.</h1>
      <p class="sub">
        Each lead page works through the same seven-part structure. Supporting entries are claim
        plus link — no detail route.
      </p>
    </header>

    <section aria-labelledby="lead-heading" class="lead">
      <h2 id="lead-heading" class="sr-only">Lead projects</h2>
      <div class="lead-grid">
        {leadProjects.map((project) => (
          <ProjectCard
            href={`/projects/${project.id}`}
            title={project.title}
            description={project.blurb}
            imageSrc={project.image}
            imageAlt={project.imageAlt}
            id={project.id}
          />
        ))}
      </div>
    </section>

    <section aria-labelledby="supporting-heading" class="supporting">
      <h2 id="supporting-heading" class="supporting-heading">Supporting work</h2>
      <ul class="supporting-strip">
        {supportingProjects.map((project) => (
          <li class="supporting-item">
            <a
              href={project.href}
              target={project.external ? '_blank' : undefined}
              rel={project.external ? 'noopener noreferrer' : undefined}
              class="supporting-link"
            >
              <span class="supporting-title">{project.title}</span>
              <span class="supporting-claim">{project.claim}</span>
              <span class="supporting-arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .projects-page {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  @media (min-width: 768px) {
    .projects-page {
      padding: 4.5rem 2rem 8rem;
    }
  }

  .page-header {
    max-width: 44rem;
    margin-bottom: 4rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-forest-floor);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1rem;
  }

  .lede {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-foreground);
    margin: 0 0 1.25rem;
  }

  .sub {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0;
    max-width: 38rem;
  }

  .lead-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .lead-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .lead-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .supporting {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-rule);
  }

  .supporting-heading {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-forest-floor);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1.5rem;
  }

  .supporting-strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .supporting-item {
    border-bottom: 1px solid var(--color-rule);
  }

  .supporting-item:first-child {
    border-top: 1px solid var(--color-rule);
  }

  .supporting-link {
    display: grid;
    grid-template-columns: minmax(10rem, 14rem) 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1.25rem 0;
    text-decoration: none;
    color: var(--color-foreground);
    transition: color 0.2s ease;
  }

  @media (max-width: 639px) {
    .supporting-link {
      grid-template-columns: 1fr auto;
      gap: 0.5rem 1rem;
    }

    .supporting-title {
      grid-column: 1 / -1;
    }
  }

  .supporting-link:hover {
    color: var(--color-accent);
  }

  .supporting-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
  }

  .supporting-claim {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.45;
  }

  .supporting-link:hover .supporting-claim {
    color: inherit;
  }

  .supporting-arrow {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--color-forest-floor);
  }

  .supporting-link:hover .supporting-arrow {
    color: var(--color-accent);
  }
</style>
