---
import BlurImage from '../components/BlurImage.astro'
import SiteFooter from '../components/SiteFooter.astro'
import { leadProjects, supportingProjects } from '../data/projects'
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Projects | Chris Lacey"
  description="Three lead projects, chosen not listed. Each carries the move paragraph."
>
  <div class="cl-page">
    <header class="page-head">
      <div class="mono mono-tiny muted">Projects · lead &amp; supporting</div>
      <h1 class="page-title serif">
        Three lead projects. <em>Chosen, not listed.</em>
      </h1>
      <p class="page-sub serif">
        The brief is "how I think," not "what I built." If a project can't carry the <em>move</em> paragraph,
        it isn't here.
      </p>
    </header>

    <section class="lead-list" aria-label="Lead projects">
      {
        leadProjects.map((p, i) => (
          <a href={`/projects/${p.id}`} class="lead-row project-card">
            <div class="lead-meta">
              <div class="mono mono-tiny muted">0{i + 1} · Lead</div>
              <div class="mono mono-tiny muted">{p.year}</div>
              <div class="mono mono-tiny accent">{p.kicker}</div>
            </div>
            <div class="lead-body">
              <h2 class="lead-title">{p.title}</h2>
              <p class="lead-claim serif">{p.detail.claim}</p>
              <div class="lead-more mono">
                <span>The move</span>
                <span class="arrow">→</span>
              </div>
            </div>
            <div class="lead-thumb project-card-wrapper">
              {p.image && p.blurDataUri ? (
                <BlurImage
                  src={p.image}
                  blurDataUri={p.blurDataUri}
                  alt={p.imageAlt ?? ''}
                  widths={[280, 560, 840, 1120]}
                  sizes="(min-width: 900px) 280px, 100vw"
                  quality={90}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  fetchpriority={i === 0 ? 'high' : 'auto'}
                />
              ) : (
                <div class="lead-thumb-placeholder">
                  <span>{p.id} · artifact</span>
                </div>
              )}
            </div>
          </a>
        ))
      }
    </section>

    <section class="support" aria-label="Supporting work">
      <div class="rule"><span class="rule-label">Supporting</span></div>
      <div class="support-list">
        {
          supportingProjects.map((s, i) => (
            <a
              class="support-row"
              href={s.href}
              target={s.external ? '_blank' : undefined}
              rel={s.external ? 'noopener noreferrer' : undefined}
            >
              <span class="mono mono-tiny muted">0{i + 1}</span>
              <span class="support-title">{s.title}</span>
              <span class="serif support-claim">{s.claim}</span>
              <span class="mono mono-tiny accent support-href">
                {s.href.replace(/^https?:\/\//, '').replace(/\/$/, '')} ↗
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .cl-page {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 80px) 120px;
  }

  .page-head {
    padding: clamp(56px, 10vw, 120px) 0 48px;
  }

  .mono-tiny {
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .muted {
    color: var(--color-muted);
  }

  .accent {
    color: var(--color-accent);
  }

  .page-title {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 500;
    margin: 16px 0 0;
    max-width: 22ch;
    color: var(--color-foreground);
  }

  .page-sub {
    font-size: 22px;
    line-height: 1.5;
    margin: 24px 0 0;
    max-width: 60ch;
    color: var(--color-foreground);
  }

  .lead-list {
    border-top: 1px solid var(--color-foreground);
  }

  .lead-row {
    display: grid;
    grid-template-columns: 180px 1fr 280px;
    gap: 48px;
    padding: 40px 0;
    border-bottom: 1px solid var(--color-rule);
    transition: background 0.25s ease;
    align-items: start;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .lead-row:hover {
    background: var(--color-tint);
  }

  .lead-row:hover .arrow {
    transform: translateX(6px);
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .lead-row {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .lead-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 8px;
  }

  .lead-title {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-foreground);
  }

  .lead-claim {
    font-size: 22px;
    line-height: 1.4;
    margin: 12px 0 0;
    max-width: 54ch;
  }

  .lead-more {
    margin-top: 20px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }

  .arrow {
    display: inline-block;
    transition: transform 0.25s ease, color 0.2s ease;
  }

  .lead-thumb {
    width: 280px;
    height: 180px;
    overflow: hidden;
    border: 1px solid var(--color-rule);
  }

  @media (max-width: 900px) {
    .lead-thumb {
      width: 100%;
      height: auto;
      aspect-ratio: 280 / 180;
    }
  }

  .lead-thumb :global(.blur-wrap) {
    width: 100%;
    height: 100%;
  }

  .lead-thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lead-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: repeating-linear-gradient(
      135deg,
      hsla(166, 33%, 27%, 0.08) 0 8px,
      hsla(166, 33%, 27%, 0.14) 8px 16px
    );
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--color-muted);
  }

  /* Rule */
  .rule {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: clamp(56px, 9vw, 120px) 0 32px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .rule::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--color-foreground);
  }

  .rule::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-rule);
  }

  .rule-label {
    white-space: nowrap;
  }

  /* Supporting list */
  .support {
    margin-top: 24px;
  }

  .support-list {
    border-top: 1px solid var(--color-rule);
  }

  .support-row {
    display: grid;
    grid-template-columns: 48px 200px 1fr 220px;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--color-rule);
    align-items: baseline;
    text-decoration: none;
    color: inherit;
    transition: color 0.2s ease;
  }

  .support-row:hover {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .support-row {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }

  .support-title {
    font-size: 20px;
    font-weight: 500;
    font-family: var(--font-display);
  }

  .support-claim {
    font-size: 16px;
    line-height: 1.45;
    color: var(--color-foreground);
  }

  .support-row:hover .support-claim {
    color: inherit;
  }

  .support-href {
    justify-self: end;
  }

  @media (max-width: 900px) {
    .support-href {
      justify-self: start;
    }
  }
</style>
