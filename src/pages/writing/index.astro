---
import { getCollection } from 'astro:content'
import SiteFooter from '../../components/SiteFooter.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { resolveWritingIndexState } from '../../lib/writing-index-state'

const essays = await getCollection('essays', ({ data }) => data.draft === false)
const state = resolveWritingIndexState(essays)

const longDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
})

// Matches "Apr 17" style shown in the design.
const shortDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: '2-digit',
  timeZone: 'UTC',
})

const lastUpdated = longDate.format(new Date())
---

<BaseLayout
  title="Writing | Chris Lacey"
  description="Essays on building AI product — intent, outcomes, and the gap between them."
>
  <div class="cl-page">
    <header class="page-head">
      <div class="mono mono-tiny muted">Writing · quarterly, at minimum</div>
      <h1 class="page-title serif">
        The quiet part, <em>written down</em>.
      </h1>
      <p class="page-sub serif">
        Essays on software I'd want to argue with. Make a claim, name the mechanism, earn the next
        paragraph.
      </p>
    </header>

    {state.mode === 'empty' && (
      <section class="empty-state" aria-labelledby="empty-heading">
        <h2 id="empty-heading" class="sr-only">Status</h2>
        <p class="empty-lede serif">First essay arriving this quarter.</p>
        <p class="empty-sub">Cadence floor is one per quarter.</p>
        <p class="empty-stamp mono">
          <span class="empty-stamp-label">As of</span>
          <time datetime={new Date().toISOString()}>{lastUpdated}</time>
        </p>
      </section>
    )}

    {state.mode === 'flat' && (
      <section class="writing-list flat" aria-labelledby="flat-heading">
        <h2 id="flat-heading" class="sr-only">Essays</h2>
        <ul class="post-list">
          {state.posts.map((post) => (
            <li class="writing-row">
              <span class="mono mono-tiny muted">
                <time datetime={post.data.pubDate.toISOString()}>
                  {shortDate.format(post.data.pubDate)}
                </time>
              </span>
              <div class="writing-body">
                <a href={`/writing/${post.id}`} class="writing-link">
                  <h3 class="writing-title serif">{post.data.title}</h3>
                  <p class="writing-annotation serif">{post.data.description}</p>
                </a>
              </div>
              <a href={`/writing/${post.id}`} class="arrow-link" aria-hidden="true">
                <span class="arrow muted">→</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {state.mode === 'year-grouped' && (
      <section class="writing-list" aria-labelledby="grouped-heading">
        <h2 id="grouped-heading" class="sr-only">Essays by year</h2>
        {state.groups.map((group) => (
          <div class="writing-year">
            <div class="writing-year-label">{group.year}</div>
            <ul class="post-list">
              {group.posts.map((post) => (
                <li class="writing-row">
                  <span class="mono mono-tiny muted">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {shortDate.format(post.data.pubDate)}
                    </time>
                  </span>
                  <div class="writing-body">
                    <a href={`/writing/${post.id}`} class="writing-link">
                      <h4 class="writing-title serif">{post.data.title}</h4>
                      <p class="writing-annotation serif">{post.data.description}</p>
                    </a>
                  </div>
                  <a href={`/writing/${post.id}`} class="arrow-link" aria-hidden="true">
                    <span class="arrow muted">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    )}

    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .cl-page {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 80px) 120px;
  }

  .page-head {
    padding: clamp(56px, 10vw, 120px) 0 48px;
  }

  .mono-tiny {
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .muted {
    color: var(--color-muted);
  }

  .page-title {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 500;
    margin: 16px 0 0;
    max-width: 22ch;
    color: var(--color-foreground);
  }

  .page-sub {
    font-size: 22px;
    line-height: 1.5;
    margin: 24px 0 0;
    max-width: 60ch;
  }

  .writing-list {
    border-top: 1px solid var(--color-foreground);
  }

  .writing-year {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 48px;
    padding: 32px 0;
    border-bottom: 1px solid var(--color-rule);
  }

  @media (max-width: 700px) {
    .writing-year {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .writing-year-label {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--color-muted);
    letter-spacing: -0.01em;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .writing-row {
    display: grid;
    grid-template-columns: 80px 1fr 40px;
    gap: 24px;
    align-items: baseline;
    padding: 18px 0;
    border-bottom: 1px dashed var(--color-rule);
    color: var(--color-foreground);
    transition: color 0.2s ease;
  }

  .writing-row:last-child {
    border-bottom: none;
  }

  .writing-row:hover {
    color: var(--color-accent);
  }

  .writing-row:hover .arrow {
    transform: translateX(6px);
    color: var(--color-accent);
  }

  .writing-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .writing-title {
    font-size: 24px;
    font-weight: 500;
    margin: 0;
    line-height: 1.3;
  }

  .writing-annotation {
    font-size: 16px;
    line-height: 1.45;
    margin: 6px 0 0;
    color: var(--color-muted);
    font-style: italic;
  }

  .writing-row:hover .writing-annotation {
    color: inherit;
  }

  .arrow {
    display: inline-block;
    transition: transform 0.25s ease, color 0.2s ease;
  }

  .arrow-link {
    text-decoration: none;
    color: inherit;
  }

  /* Flat mode: no year column, so collapse to a single list */
  .flat {
    padding-top: 8px;
  }

  .flat .writing-row:first-child {
    border-top: 1px dashed transparent;
  }

  /* Empty state */
  .empty-state {
    border-top: 1px solid var(--color-rule);
    padding-top: 2.5rem;
  }

  .empty-lede {
    font-size: 1.5rem;
    line-height: 1.35;
    color: var(--color-foreground);
    margin: 0 0 0.5rem;
  }

  .empty-sub {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-muted);
    margin: 0 0 2rem;
  }

  .empty-stamp {
    font-size: 0.8125rem;
    color: var(--color-forest-floor);
    margin: 0;
  }

  .empty-stamp-label {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-right: 0.5rem;
  }
</style>
