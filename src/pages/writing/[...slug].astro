---
import { type CollectionEntry, getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) => data.draft === false)
  return essays.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

type Props = { post: CollectionEntry<'essays'> }

const { post } = Astro.props
const { Content } = await render(post)

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
})
---

<BaseLayout title={`${post.data.title} | Chris Lacey`} description={post.data.description}>
  <article class="essay">
    <header class="essay-header">
      <p class="eyebrow">Essay</p>
      <h1 class="essay-title">{post.data.title}</h1>
      <p class="essay-description">{post.data.description}</p>
      <p class="essay-meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {dateFormatter.format(post.data.pubDate)}
        </time>
        {post.data.updatedDate && (
          <>
            <span class="essay-meta-sep" aria-hidden="true">·</span>
            <span>
              Updated
              {' '}
              <time datetime={post.data.updatedDate.toISOString()}>
                {dateFormatter.format(post.data.updatedDate)}
              </time>
            </span>
          </>
        )}
      </p>
    </header>

    <div class="essay-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .essay {
    max-width: 65ch;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  @media (min-width: 768px) {
    .essay {
      padding: 4.5rem 1.5rem 8rem;
    }
  }

  .essay-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-rule);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-forest-floor);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1rem;
  }

  .essay-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-foreground);
    margin: 0 0 1rem;
  }

  .essay-description {
    font-family: var(--font-display);
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0 0 1.5rem;
  }

  .essay-meta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-forest-floor);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  .essay-meta-sep {
    margin: 0 0.5rem;
  }

  .essay-body {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    line-height: 1.65;
    color: var(--color-foreground);
  }

  .essay-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 3rem 0 1rem;
  }

  .essay-body :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 2.5rem 0 0.75rem;
  }

  .essay-body :global(p) {
    margin: 0 0 1.25rem;
  }

  .essay-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .essay-body :global(a:hover) {
    text-decoration-thickness: 2px;
  }

  .essay-body :global(ul),
  .essay-body :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .essay-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .essay-body :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    margin: 1.75rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .essay-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgba(47, 93, 80, 0.08);
    padding: 0.125rem 0.35rem;
    border-radius: 3px;
  }

  .essay-body :global(pre) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.55;
    background: var(--color-foreground);
    color: var(--color-background);
    padding: 1.25rem 1.5rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .essay-body :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .essay-body :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-rule);
    margin: 3rem 0;
  }
</style>
