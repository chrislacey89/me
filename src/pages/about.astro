---
import { Image } from 'astro:assets'
import headshot from '../assets/headshot.jpeg'
import SiteFooter from '../components/SiteFooter.astro'
import aboutData from '../data/about.json'
import BaseLayout from '../layouts/BaseLayout.astro'

const { lede, how, pipeline, where, objects } = aboutData
---

<BaseLayout
  title="About | Chris Lacey"
  description="Full-stack AI product engineer working from Bloomington, Indiana."
>
  <div class="cl-page">
    <header class="page-head">
      <div class="mono mono-tiny muted">About · how I work</div>
      <h1 class="page-title serif">
        The seams are where the work gets <em>interesting</em>.
      </h1>
    </header>

    <section class="about-body">
      <div class="about-main">
        <section class="section">
          <div class="section-label mono">Lede</div>
          <div class="section-body">
            <p class="serif large-serif">{lede}</p>
          </div>
        </section>

        <section class="section">
          <div class="section-label mono">How I work</div>
          <div class="section-body">
            <p class="serif">{how}</p>
            <div class="pipeline mono">
              {
                pipeline.map((step, i) => (
                  <>
                    <span class:list={{ accent: i === pipeline.length - 1 }}>{step}</span>
                    {i < pipeline.length - 1 && <span aria-hidden="true">→</span>}
                  </>
                ))
              }
            </div>
          </div>
        </section>

        <section class="section">
          <div class="section-label mono">Where I am</div>
          <div class="section-body">
            <p class="serif">{where}</p>
          </div>
        </section>

        <section class="section">
          <div class="section-label mono">Desk objects</div>
          <div class="section-body">
            <ul class="objects">
              {objects.map((o) => <li class="serif">{o}</li>)}
            </ul>
          </div>
        </section>
      </div>

      <aside class="about-side">
        <figure class="portrait">
          <Image
            src={headshot}
            alt="Portrait of Chris Lacey"
            class="portrait-img"
            width={320}
            densities={[1, 2]}
            quality={90}
          />
        </figure>
        <a class="resume-link" href="/resume.pdf">
          <span class="mono mono-tiny muted">Résumé</span>
          <span class="resume-title">Download PDF</span>
          <span class="arrow">↓</span>
        </a>
      </aside>
    </section>

    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .cl-page {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 80px) 120px;
  }

  .page-head {
    padding: clamp(56px, 10vw, 120px) 0 48px;
  }

  .mono-tiny {
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .muted {
    color: var(--color-muted);
  }

  .accent {
    color: var(--color-accent);
  }

  .page-title {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 500;
    margin: 16px 0 0;
    max-width: 22ch;
    color: var(--color-foreground);
  }

  .about-body {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 64px;
  }

  @media (max-width: 900px) {
    .about-body {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .section {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 32px;
    padding: 32px 0;
    border-bottom: 1px solid var(--color-rule);
    align-items: start;
  }

  @media (max-width: 700px) {
    .section {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .section-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding-top: 8px;
  }

  .section-body p.serif {
    font-size: 19px;
    line-height: 1.55;
    margin: 0;
    color: var(--color-foreground);
  }

  .section-body .large-serif {
    font-size: 24px;
    line-height: 1.45;
  }

  .pipeline {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 20px;
    font-size: 14px;
    color: var(--color-muted);
  }

  .pipeline .accent {
    color: var(--color-accent);
  }

  .objects {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .objects li {
    font-size: 18px;
    padding: 10px 0;
    border-bottom: 1px dashed var(--color-rule);
    line-height: 1.4;
  }

  .objects li:last-child {
    border-bottom: none;
  }

  /* Side */
  .about-side {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .portrait {
    margin: 0;
    aspect-ratio: 320 / 380;
    overflow: hidden;
    border: 1px solid var(--color-rule);
    background: var(--color-tint);
  }

  .portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .resume-link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 20px;
    border: 1px solid var(--color-rule);
    text-decoration: none;
    color: var(--color-foreground);
    transition: background 0.25s ease;
  }

  .resume-link:hover {
    background: var(--color-tint);
  }

  .resume-title {
    font-size: 18px;
    font-weight: 500;
  }

  .arrow {
    display: inline-block;
    transition: transform 0.25s ease, color 0.2s ease;
  }

  .resume-link:hover .arrow {
    transform: translateY(4px);
    color: var(--color-accent);
  }
</style>
